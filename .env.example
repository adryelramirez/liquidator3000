# Copie para .env e preencha. NUNCA versione o .env.

# Porta (Render injeta PORT automaticamente).
PORT=8787

# Chave de acesso que o app envia no header x-api-key.
# Gere algo longo e aleatório. Vaza? No máximo mandam lixo cifrado pro dev.
REPORT_API_KEY=troque-por-uma-string-longa-aleatoria

# Destino FIXO dos reports. O cliente nunca escolhe destino.
REPORT_RECIPIENT=liquidator3000psfrgr@gmail.com

# Brevo (API HTTP, grátis 300/dia, sem precisar de domínio).
# 1. Crie conta em brevo.com com o Gmail dedicado.
# 2. Adicione/valide o sender (o próprio Gmail dedicado).
# 3. Gere a API key em: SMTP & API > API Keys.
BREVO_API_KEY=xkeysib-...
BREVO_SENDER=liquidator3000psfrgr@gmail.com

# Limite anti-abuso.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MIN=15
